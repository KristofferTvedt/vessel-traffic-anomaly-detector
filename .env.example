# --- BarentsWatch AIS API (live positions) ---
# Free client registration: https://developer.barentswatch.no/ (My page -> API access).
# OAuth2 client-credentials: id/secret are posted in the token body, scope "ais".
# The live collector and the site's /api/vessels proxy both use these.
BW_CLIENT_ID=
BW_CLIENT_SECRET=

# --- Area of interest ---
# Bounding box for the slice of coast we watch (Bergen approaches / Korsfjorden).
# min_lon,min_lat,max_lon,max_lat in WGS84 degrees.
AOI_NAME=Bergen-approaches
AOI_MIN_LON=4.90
AOI_MIN_LAT=60.10
AOI_MAX_LON=5.55
AOI_MAX_LAT=60.55

# --- Historical AIS (Kystverket, offline training/validation) ---
# Open data, no auth: https://ais-public.kystverket.no/ (NLOD licence).
# Downloaded CSV/exports go here; the loader maps columns via an alias table
# (see vesselwatch/kystverket.py) because the export headers vary.
RAW_DIR=raw

# SQLite database path
DB_PATH=data/vessels.db
